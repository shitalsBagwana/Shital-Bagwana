<div
  class="tisso_vision_main_wrapper"
>
  <div class="tisso_conatianer">
    <!-- Heading -->
    <div class="tisso_heading">
      {% if section.settings.section_title != blank %}
        <h2>{{ section.settings.section_title }}</h2>
      {% endif %}
    </div>

    <div class="popup-overlay"></div>
    <!-- Product Grid -->
    <div
      class="tisso_product_grid"
      {% comment %} style="gap: {{ section.settings.grid_gap }}px;" {% endcomment %}
    >
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}

        {% if product != blank %}
          <div class="tisso_product_col">
            <div class="tisso_product">
              <!-- Product Image -->
              <div class="tisso_product_image">
                <img
                  src="{{ product.featured_image | img_url: 'master' }}"
                  alt="{{ product.title }}"
                  width=""
                  height=""
                >
              </div>
              <div
                class="dot-area"
                style="
                  top: {{ block.settings.dot_top }}%;
                  left: {{ block.settings.dot_left }}%;
                "
              >
                <span class="plusDog">
                  {% render 'dots' %}
                </span>
              </div>
            </div>
            <div class="main-popup">
              <div class="popupCross">{% render 'crossIcon' %}</div>
              <div class="product-row-box">
                <div class="product-popupimage">
                  <img
                    src="{{ product.featured_image | img_url: 'master' }}"
                    alt="{{ product.title }}"
                    width=""
                    height=""
                  >
                </div>
                <div class="product_description_box">
                  <h5>{{ product.title }}</h5>
                  <h2>{{ product.price | money_with_currency }}</h2>
                  {{ product.description }}
                </div>
              </div>
              <div class="product_options">
                <div class="product-variant hidden">
                  {% for variant in product.variants %}
                    <span
                      class="variant_box"
                      productVariant="{{ variant.title }}"
                      productId="{{ variant.id }}"
                    >
                      {{ variant.title }}
                    </span>
                  {% endfor %}
                </div>

                <div class="custom_variant_wrapper">
                  {% for option in product.options_with_values %}
                    <div class="variant_block">
                      <label class="variant_label">{{ option.name }}</label>
                      {% if option.name == 'Color' %}
                        <div class="color_options">
                          {% for value in option.values %}
                            <div
                              class="option_button"
                              optionAttr="{{ value }}"
                            >
                              <span
                                class="color_swatch"
                                style="background-color: {{ value | downcase }};"
                              ></span>
                              <div class="value_span">{{ value }}</div>
                            </div>
                          {% endfor %}
                        </div>

                      {% elsif option.name == 'Size' %}
                        <div class="select">
                          <select name="id" class="productSelect">
                            <option disabled selected>Choose your size</option>

                            {% for value in option.values %}
                              <option optionvalue="{{ value }}">
                                {{ value }}
                              </option>
                            {% endfor %}
                          </select>
                        </div>
                      {% endif %}
                    </div>
                  {% endfor %}
                </div>
              </div>

              <div class="product-button">
                {% if product.available %}
                  <button
                    class="button_bundle"
                    data-id="{{ product.variants.first.id }}"
                  >
                    Add to cart
                    <span>{% render 'btn-arrow' %}</span>
                  </button>
                {% else %}
                  <button class="button_bundle out_of_stock" disabled>Out of stock</button>
                {% endif %}
              </div>
            </div>
          </div>

          {% comment %} product popup {% endcomment %}
          {% comment %}
            <div class="main-popup">
              <div class="popupCross">{% render 'crossIcon' %}</div>
              <div class="product-row-box">
                <div class="product-popupimage">
                  <img
                    src="{{ product.featured_image | img_url: 'master' }}"
                    alt="{{ product.title }}"
                    width=""
                    height=""
                  >
                </div>
                <div class="product_description_box">
                  <h5>{{ product.title }}</h5>
                  <h2>{{ product.price | money_with_currency }}</h2>
                  {{ product.description }}
                </div>
              </div>
              <div class="product_options">
                <div class="product-variant hidden">
                  {% for variant in product.variants %}
                    <span
                      class="variant_box"
                      productVariant="{{ variant.title }}"
                      productId="{{ variant.id }}"
                    >
                      {{ variant.title }}
                    </span>
                  {% endfor %}
                </div>

                <div class="custom_variant_wrapper">
                  {% for option in product.options_with_values %}
                    <div class="variant_block">
                      <label class="variant_label">{{ option.name }}</label>
                      {% if option.name == 'Color' %}
                        <div class="color_options">
                          {% for value in option.values %}
                            <div
                              class="option_button"
                              optionAttr="{{ value }}"
                            >
                              <span
                                class="color_swatch"
                                style="background-color: {{ value | downcase }};"
                              ></span>
                              <div class="value_span">{{ value }}</div>
                            </div>
                          {% endfor %}
                        </div>

                      {% elsif option.name == 'Size' %}
                        <div class="select">
                          <select name="id" class="productSelect">
                            <option disabled selected>Choose your size</option>

                            {% for value in option.values %}
                              <option optionvalue="{{ value }}">
                                {{ value }}
                              </option>
                            {% endfor %}
                          </select>
                        </div>
                      {% endif %}
                    </div>
                  {% endfor %}
                </div>
              </div>

              <div class="product-button">
                {% if product.available %}
                  <button
                    class="button_bundle"
                    data-id="{{ product.variants.first.id }}"
                  >
                    Add to cart
                  </button>
                {% else %}
                  <button class="button_bundle out_of_stock" disabled>Out of stock</button>
                {% endif %}
              </div>
            </div>
          {% endcomment %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Tisso Vision Product",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Tisso vision in the wild"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid Spacing",
      "min": 0,
      "max": 30,
      "step": 5,
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product Item",
      "limit": 6,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "range",
          "id": "dot_top",
          "label": "Dot Vertical Position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "range",
          "id": "dot_left",
          "label": "Dot Horizontal Position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tisso Vision Grid"
    }
  ]
}
{% endschema %}
